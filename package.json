{
  "name": "1router",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/site",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@1router/site",
    "dev:site": "turbo run dev --filter=@1router/site",
    "dev:api": "cargo run --manifest-path apps/api/Cargo.toml",
    "build": "turbo run build && cargo build --release --manifest-path apps/api/Cargo.toml",
    "build:site": "turbo run build --filter=@1router/site",
    "build:api": "cargo build --release --manifest-path apps/api/Cargo.toml",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.1.0"
  }
}
