# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies (anywhere in the monorepo) ───────────────
# `**/node_modules` matches node_modules at any depth, including
# hoisted (bun/npm/yarn-style) and per-package (pnpm-style) layouts.
**/node_modules/
**/node_modules
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Standalone Next.js output (when `output: 'standalone'` is enabled)
/.next/standalone/
/.next/static/

# Production bundles
/build

# Misc
.DS_Store
Thumbs.db
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Env files (opt-in for committing if needed)
.env
.env.local
.env.*.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ─── Monorepo additions ─────────────────────────────────────

# Turborepo
/.turbo/

# Rust target + the catalog that build.rs generates
/apps/api/target/
/apps/api/catalog/

# General build outputs at any depth
/dist/
/build/

# Bun / Pnpm caches
/.bun/
/.pnpm-store/

# IDE / OS junk
.vscode/
.idea/
*.swp
*~
